{
  "name": "devcloud-backend",
  "version": "1.0.0",
  "description": "DevCloud API Server",
  "private": true,
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "migrate": "tsx src/database/migrations.ts",
    "seed": "tsx src/database/seed.ts",
    "lint": "eslint src --ext .ts",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "express": "^4.18.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.0",
    "pg": "^8.11.0",
    "redis": "^4.6.0",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.0",
    "socket.io": "^4.7.0",
    "axios": "^1.6.0",
    "minio": "^7.1.0",
    "pino": "^8.16.0",
    "pino-http": "^8.5.0",
    "zod": "^3.22.0",
    "express-async-errors": "^3.1.1"
  },
  "devDependencies": {
    "typescript": "^5.3.0",
    "@types/express": "^4.17.0",
    "@types/node": "^20.10.0",
    "@types/bcryptjs": "^2.4.2",
    "tsx": "^4.6.0",
    "eslint": "^8.55.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0"
  }
}
